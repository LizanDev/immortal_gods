{
  "buildCommand": "DATABASE_URL='' python manage.py collectstatic --noinput",
  "outputDirectory": "staticfiles",
  "devCommand": "python manage.py runserver",
  "framework": null,
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.py" }
  ]
}
